# Secret references for 1Password. Safe to commit — these are references
# to items in the `devops` vault, not the values themselves.
#
# Use with:
#   op run --env-file=.env.1password -- <command>
#
# Or via the helper:
#   ./scripts/with-secrets.sh <command>
#
# Requires: 1Password CLI signed in (`op signin`), access to the devops vault.

CIRCLE_TOKEN=op://devops/levlaz-ci/CIRCLE_TOKEN
GITHUB_TOKEN=op://devops/levlaz-ci/GITHUB_TOKEN
